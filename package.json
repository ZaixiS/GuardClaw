{
  "name": "guardclaw",
  "version": "0.1.0",
  "description": "AI Agent Safety Monitor with LLM-based Command Safeguard",
  "main": "electron/main.cjs",
  "type": "module",
  "bin": {
    "guardclaw": "./bin/guardclaw.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && vite",
    "build": "cd client && vite build",
    "start": "node server/index.js",
    "test": "echo \"Tests coming soon\" && exit 0",
    "electron:dev": "concurrently \"npm run server:dev\" \"cd client && vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "electron:build": "cd client && vite build && electron-builder --mac",
    "electron:pack": "cd client && vite build && electron-builder --mac --publish=never"
  },
  "keywords": [
    "openclaw",
    "agent",
    "monitoring",
    "safety",
    "ai",
    "llm"
  ],
  "author": "YG",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/TobyGE/GuardClaw.git"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "dotenv": "^16.4.1",
    "@anthropic-ai/sdk": "^0.27.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
